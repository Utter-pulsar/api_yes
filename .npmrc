# Build native deps against Electron's ABI, not system Node.
runtime=electron

# NOTE: the Electron binary mirror is intentionally NOT pinned here. Committing a
# mainland-China mirror (npmmirror) makes GitHub Actions runners time out on
# `npm install` (ETIMEDOUT, the runner can't reach the CN mirror). CI uses the default.
# For fast local installs in China, set it in your GLOBAL ~/.npmrc instead:
#   npm config set electron_mirror https://npmmirror.com/mirrors/electron/
